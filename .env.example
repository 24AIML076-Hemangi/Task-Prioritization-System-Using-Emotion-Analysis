# SMTP email reminder configuration
# For Gmail:
# 1) Enable 2-step verification
# 2) Generate App Password
# 3) Put your Gmail + app password below

# App and security
SECRET_KEY=change-this-secret
JWT_SECRET_KEY=change-this-jwt-secret
ADMIN_SECRET_KEY=your_secret_key_here
JWT_ACCESS_EXPIRES_SECONDS=3600
JWT_REFRESH_EXPIRES_SECONDS=2592000
FLASK_DEBUG=0

# Database
# DATABASE_URL should be set in Render. Locally, the app will fall back to SQLite (Backend/tasks.db).
DATABASE_URL=
# Example (format only): postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# Optional startup migration: copy data from SQLite into PostgreSQL on every app start (idempotent)
SQLITE_MIGRATE_ON_STARTUP=1
SQLITE_SOURCE_DB=Backend/tasks.db

# CORS and rate limiting
CORS_ORIGINS=http://localhost:5000
RATELIMIT_STORAGE_URI=memory://

# Disable outbound email in local/dev
DISABLE_EMAIL=1

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Optional SendGrid instead of SMTP
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM=verified-sender@example.com

# Optional per-user Gmail OAuth sender (recommended for "send from logged-in user")
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google-mail/callback

# SMS with Twilio
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM=+1xxxxxxxxxx

# Daily reminder scheduler (UTC hour)
REMINDER_DAILY_HOUR_UTC=8
